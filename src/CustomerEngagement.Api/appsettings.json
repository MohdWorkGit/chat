{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=customer_engagement;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_TO_A_SECURE_SECRET_AT_LEAST_32_CHARS",
    "Issuer": "CustomerEngagement",
    "Audience": "CustomerEngagement",
    "ExpiryMinutes": "60",
    "RefreshTokenExpiryDays": "7"
  },
  "Redis": {
    "Url": "localhost:6379"
  },
  "Storage": {
    "Provider": "S3",
    "S3": {
      "AccessKey": "",
      "SecretKey": "",
      "BucketName": "customer-engagement",
      "Region": "us-east-1",
      "Endpoint": "http://localhost:9000",
      "ForcePathStyle": true
    }
  },
  "Email": {
    "Smtp": {
      "Host": "localhost",
      "Port": 587,
      "Username": "",
      "Password": "",
      "FromAddress": "noreply@example.com",
      "FromName": "Customer Engagement",
      "EnableSsl": true
    },
    "Imap": {
      "Host": "localhost",
      "Port": 993,
      "Username": "",
      "Password": "",
      "EnableSsl": true,
      "PollIntervalSeconds": 60
    }
  },
  "Vapid": {
    "Subject": "mailto:admin@example.com",
    "PublicKey": "",
    "PrivateKey": ""
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3"
  },
  "Rasa": {
    "BaseUrl": "http://localhost:5005"
  },
  "GeoIp": {
    "DatabasePath": "./data/GeoLite2-City.mmdb"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3100"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
